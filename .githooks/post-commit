#!/bin/sh
[ "${SKIP_GRAPHIFY_SYNC:-}" = "1" ] && exit 0
APP="es"
REPO="$(git rev-parse --show-toplevel)"
SYNC="$REPO/../../scripts/sync-graphs.ps1"
[ -f "$SYNC" ] || exit 0
WSYNC="$(cd "$(dirname "$SYNC")" && pwd -W 2>/dev/null)/$(basename "$SYNC")"
[ -f "$WSYNC" ] || WSYNC="$SYNC"
if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -Command "Start-Process -FilePath powershell.exe -ArgumentList @('-NoProfile','-WindowStyle','Hidden','-ExecutionPolicy','Bypass','-File','$WSYNC','-App','$APP') -WindowStyle Hidden" >/dev/null 2>&1 || true
fi
exit 0
