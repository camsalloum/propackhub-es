#!/bin/sh
# graphify knowledge-graph auto-refresh (IDE-agnostic: fires on every merge).
# NOTE: Do NOT use `cmd //c start "" /B ...` — Git Bash converts /B to B:/ and pops an error dialog.
APP="es"
REPO="$(git rev-parse --show-toplevel)"
SYNC="$REPO/../../scripts/sync-graphs.ps1"
[ -f "$SYNC" ] || exit 0
WSYNC="$(cd "$(dirname "$SYNC")" && pwd -W 2>/dev/null)/$(basename "$SYNC")"
[ -f "$WSYNC" ] || WSYNC="$SYNC"
if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File "$WSYNC" -App "$APP" >/dev/null 2>&1 &
fi
exit 0
