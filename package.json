{
  "name": "propackhub-es",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace=packages/engine",
    "dev": "concurrently \"npm:dev:*\"",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev:web-delayed": "ping -n 4 127.0.0.1 >nul && npm run dev --workspace=packages/web",
    "start": "npm run dev",
    "start:servers": "npm run build --workspace=packages/engine && concurrently -k -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "start:servers:dev": "concurrently -k -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "db:sync-materials": "npm run db:sync-materials --workspace=packages/server"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pdfkit": "^0.13.9",
    "@types/pg": "^8.20.0",
    "@types/three": "0.168.0",
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@types/three": "0.168.0"
  }
}
