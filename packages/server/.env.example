# Database
DATABASE_URL=postgresql://user:password@localhost:5432/estimation_studio
# Integration tests (vitest) require a dedicated *_test DB — never point tests at dev estimation_studio.
# CI uses estimation_studio_test. One-time cleanup: npm run db:purge-integration-artifacts
# ES_INTEGRATION_TESTS_ALLOW_ANY_DB=1  # escape hatch only — tests will pollute that database
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_KEEP_ALIVE=true
DB_KEEP_ALIVE_INITIAL_DELAY_MS=10000

# Server
PORT=5001
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Optional first-boot admin (disabled by default)
# ADMIN_SEED_ENABLED=1
# ADMIN_SEED_EMAIL=admin@propackhub.com
# ADMIN_SEED_PASSWORD=use-a-strong-password

# Interplast company tenant (npm run db:provision-interplast)
# INTERPLAST_ADMIN_EMAIL=camille@interplast-uae.com
# INTERPLAST_ADMIN_PASSWORD=Admin@123
# INTERPLAST_PLATFORM_COMPANY_CODE=interplast

# PEBI ↔ ES integration sync (npm run db:sync-customers-pebi | db:sync-materials-pebi)
# Auto sync: ES watches PEBI rm_last_sync / oracle_last_sync; pulls 15 min after each PB cron
# PEBI_SYNC_ENABLED=true
# PEBI_ES_SYNC_DELAY_MS=900000
# PEBI_ORACLE_SYNC_POLL_MS=60000
# PEBI_AUTH_DATABASE_URL=postgresql://postgres:password@localhost:5432/ip_auth_database
# — or poll via PEBI API when ES has no auth DB access:
# PEBI_API_URL=http://localhost:3001
PEBI_DATABASE_URL=postgresql://postgres:password@localhost:5432/fp_database
# Or live API when both servers run:
# PEBI_API_URL=http://localhost:3001
PEBI_ES_INTEGRATION_SECRET=change_me_dev_integration_secret

# CORS
CORS_ORIGIN=http://localhost:5000

# FX API (for auto currency conversion)
FX_API_KEY=your-fxapi-key
FX_API_URL=https://api.exchangerate-api.com/v4/latest/USD
