# Database
DATABASE_URL=postgresql://user:password@localhost:5432/estimation_studio
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_KEEP_ALIVE=true
DB_KEEP_ALIVE_INITIAL_DELAY_MS=10000

# Server
PORT=5001
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:5000

# FX API (for auto currency conversion)
FX_API_KEY=your-fxapi-key
FX_API_URL=https://api.exchangerate-api.com/v4/latest/USD
