{
  "name": "@es/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --exclude src/db/master-materials-seed.json src/index.ts",
    "update-materials": "tsx src/scripts/update-materials-from-excel.ts",
    "db:sync-materials": "tsx scripts/sync-materials.ts",
    "db:prune-orphan-substrates": "tsx scripts/prune-orphan-substrates.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push:pg",
    "db:patch": "tsx scripts/apply-schema-patches.ts",
    "db:seed-templates": "tsx scripts/seed-templates-backfill.ts",
    "db:generate": "drizzle-kit generate:pg",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "pdf:test": "tsx src/scripts/generate_proposal_local.ts"
  },
  "dependencies": {
    "@es/engine": "*",
    "xlsx": "^0.18.5",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/type-provider-typebox": "^4.0.0",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.26.2",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "optionalDependencies": {
    "pdfkit": "^0.13.0",
    "puppeteer": "^21.0.0",
    "svg-to-pdfkit": "^1.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.12",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.57.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
  }
}
