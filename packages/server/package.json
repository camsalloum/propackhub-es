    "drizzle-orm": "^0.30.10",
    "pg": "^8.11.3",
    "fastify": "^4.26.2",
    "zod": "^3.22.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5"
  },
  "optionalDependencies": {
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.57.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
