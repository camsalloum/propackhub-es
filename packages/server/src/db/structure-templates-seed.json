{
  "version": 4,
  "description": "PEBI-aligned templates: 11 parent product groups with variants as subcards. PE mono = one PE substrate; Printed adds Ink SB. Defaults provisional — owner will refine. Lamination Film (SFG) excluded. Supersedes Decision #17 (parent-only).",
  "rules": {
    "pe_mono": "substrate_origin=PE → exactly one PE substrate layer",
    "print_status": "Unprinted/Plain → no ink; Printed → Ink SB (wide web default); Others → infer from name or add ink when printed product",
    "multilayer": "Laminates variants define stack; PE may appear only as sealant layer after adhesive"
  },
  "material_model": {
    "layer_types": ["substrate", "ink", "adhesive"],
    "ink_systems": {
      "SB": {
        "label": "Solvent Based",
        "solid_percent": 30,
        "solvent_mix_required": true,
        "printing_web_class": "wide_web",
        "notes": "Wide web printing → Ink SB + ink-to-solvent ratio block."
      },
      "UV": {
        "label": "UV",
        "solid_percent": 100,
        "solvent_mix_required": false,
        "printing_web_class": "narrow_web",
        "notes": "Narrow web printing → Ink UV. No solvent block for ink."
      }
    },
    "printing_web_class": {
      "wide_web": { "label": "Wide Web printing", "ink_key": "ink-sb", "default": true },
      "narrow_web": { "label": "Narrow Web printing", "ink_key": "ink-uv" }
    },
    "adhesive_systems": {
      "SB": { "label": "Adhesive SB", "notes": "Solvent-based lamination adhesive." }
    },
    "global_inputs": {
      "solvent_mix": "Not a layer — cost/kg + ink-to-solvent GSM ratio; only when stack has SB ink and/or SB adhesive"
    }
  },
